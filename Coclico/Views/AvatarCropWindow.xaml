<Window x:Class="Coclico.Views.AvatarCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crop Avatar" Width="520" Height="620"
        Icon="/Resources/icone/plage.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgElevatedBrush}" CornerRadius="{StaticResource CornerSmall}" Padding="12">
            <Grid>
                <Viewbox Stretch="Uniform">
                    <Grid Width="400" Height="400" ClipToBounds="True">
                        <Canvas x:Name="ImageCanvas" Background="Transparent">
                            <Image x:Name="SrcImage" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Canvas>
                        
                        <Rectangle Width="256" Height="256" Stroke="White" StrokeThickness="2" RadiusX="8" RadiusY="8" Opacity="0.9"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <Rectangle Width="256" Height="256" Fill="#80000000" IsHitTestVisible="False">
                            <Rectangle.OpacityMask>
                                <VisualBrush Stretch="None" Visual="{Binding ElementName=SrcImage}"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Grid>
                </Viewbox>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Slider x:Name="ZoomSlider" Minimum="0.5" Maximum="3" Value="1" Width="300" ValueChanged="ZoomSlider_ValueChanged"/>
                <TextBlock x:Name="ZoomLabel" Text="100%" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Annuler" Style="{StaticResource GhostButton}"
                        Width="100" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="Enregistrer" Style="{StaticResource PrimaryButton}"
                        Width="120" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

