<UserControl x:Class="Coclico.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="{DynamicResource BgBaseBrush}" d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PageRoot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="PageSlide"
                                     Storyboard.TargetProperty="Y"
                                     From="14" To="0" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="PageRoot" Margin="32,24,32,32" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PageSlide" Y="0"/>
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="{DynamicResource Help_Guide}" FontSize="9" FontWeight="Black"
                       Foreground="{DynamicResource TextMutedBrush}" Margin="4,0,0,12"
                       FontFamily="Consolas, Courier New"/>
            <ListBox Background="Transparent" BorderThickness="0" SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,8"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="SelectionStates">
                                                <VisualState x:Name="Selected">
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bd" Storyboard.TargetProperty="Background">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{DynamicResource BgPanelBrush}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </VisualState>
                                                <VisualState x:Name="Unselected"/>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem Tag="Guide" Selected="Section_Click" IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="BookOpen24" FontSize="15" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Help_Guide}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="Changelog" Selected="Section_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Sparkle24" FontSize="15" Foreground="{DynamicResource SecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Help_Whats_New}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </StackPanel>

        
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                
                <Border x:Name="PanelGuide" CornerRadius="{DynamicResource CornerCard}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                        Padding="24,20" Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0D0818" Offset="0"/>
                            <GradientStop Color="#08050F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Help_Guide}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{DynamicResource Help_Guide_Subtitle}" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,20"/>
                        
                        <Border Height="1" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#3B0764" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="0.6"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        
                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#4A1FA8" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="Home24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_Dashboard}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Dashboard_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#16A34A" Offset="0"/><GradientStop Color="#059669" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="Apps24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_Programs}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Programs_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#6B2FD9" Offset="0"/><GradientStop Color="#BE185D" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="Branch24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_WorkflowPipelines}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Flow_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#D97706" Offset="0"/><GradientStop Color="#B45309" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="Link24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_Chains}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Chains_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#0E4A6A" Offset="0"/><GradientStop Color="#0284C7" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_Installer}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Installer_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#991B1B" Offset="0"/><GradientStop Color="#DC2626" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="Delete24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_Cleaning}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Cleaning_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#0E4A6A" Offset="0"/><GradientStop Color="#0EA5E9" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="SearchSquare24" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_Scanner}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_Scanner_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border CornerRadius="{StaticResource CornerNode}" Padding="16,12" Margin="0,0,0,0"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Width="38" Height="38" CornerRadius="{StaticResource CornerNode}" VerticalAlignment="Top">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#4A1FA8" Offset="0"/><GradientStop Color="#7C3AED" Offset="1"/></LinearGradientBrush></Border.Background>
                                    <ui:SymbolIcon Symbol="Memory16" FontSize="17" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="{DynamicResource Menu_RamCleaner}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{DynamicResource Help_RamCleaner_Desc}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                
                <Border x:Name="PanelChangelog" Visibility="Collapsed"
                        CornerRadius="{DynamicResource CornerCard}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                        Padding="24,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0D0818" Offset="0"/>
                            <GradientStop Color="#08050F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Help_Whats_New}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{DynamicResource Help_Changelog_Subtitle}" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,20"/>
                        <Border Height="1" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#3B0764" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="0.6"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        
                        <Border CornerRadius="{StaticResource CornerNode}" Padding="22,18" Margin="0,0,0,24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A0830" Offset="0"/>
                                    <GradientStop Color="#2D1060" Offset="0.5"/>
                                    <GradientStop Color="#4A1080" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#7C3AED" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Background="#30FFFFFF" CornerRadius="6" Padding="8,4" Margin="0,0,10,0">
                                        <TextBlock Text="v1.0.4" FontSize="11" FontWeight="ExtraBold" Foreground="White"/>
                                    </Border>
                                    <Border Background="#30FFFFFF" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="{DynamicResource Help_Latest}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{DynamicResource Help_Changelog_V2_Title}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{DynamicResource Help_V2_Date}" FontSize="12" Foreground="#CCFFFFFF" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        
                        <TextBlock Text="{DynamicResource Help_Design_Section}" FontSize="9" FontWeight="Black"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10"
                                   FontFamily="Consolas, Courier New"/>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Design1}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Design2}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,20"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Design3}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        
                        <TextBlock Text="{DynamicResource Help_Fixes_Section}" FontSize="9" FontWeight="Black"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10"
                                   FontFamily="Consolas, Courier New"/>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bug24" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Fix1}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bug24" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Fix2}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bug24" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Fix3}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bug24" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Fix4}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,20"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bug24" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_Fix5}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        
                        <TextBlock Text="{DynamicResource Help_New_Section}" FontSize="9" FontWeight="Black"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10"
                                   FontFamily="Consolas, Courier New"/>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#0F0A1E" Offset="0"/><GradientStop Color="#0A0614" Offset="1"/></LinearGradientBrush></Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="13" Foreground="{DynamicResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{DynamicResource Help_Changelog_New1}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="{StaticResource CornerSmall}" Padding="14,10" Margin="0,0,0,6"
