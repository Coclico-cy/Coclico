<UserControl x:Class="Coclico.Views.WorkflowPipelinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Coclico.ViewModels"
             xmlns:models="clr-namespace:Coclico.Models"
             xmlns:converters="clr-namespace:Coclico.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Background="{DynamicResource BgBaseBrush}"
             Tag="{Binding IsCompact}">

    <UserControl.Resources>
        
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BooleanToVisibilityInvertedConverter x:Key="BoolToVisInv"/>

        
        <Style x:Key="FC.Btn" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FC.AccentBtn" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FC.GreenBtn" TargetType="Button" BasedOn="{StaticResource SuccessButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FC.RedBtn" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>


        <Style x:Key="FC.IconBtn" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        
        <Style x:Key="FC.InsertBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgBaseBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource CornerNode}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="FC.TypeCard" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        
        <Style x:Key="FC.ChainLbi" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A0D35"/>
                                <Setter Property="Foreground" Value="#8B7AAE"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F4C6EF5"/>
                                <Setter Property="Foreground" Value="#9FB8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0" Background="#0D0818" BorderBrush="#12121E" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,16,16,12" BorderBrush="#1E1030" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="CHAÎNES D'ACTIONS" FontSize="9" FontWeight="Black"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                            <Run Text="{Binding Chains.Count, Mode=OneWay}"/>
                            <Run Text=" chaîne(s)"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Chains}"
                         SelectedItem="{Binding SelectedChain}"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource FC.ChainLbi}"
                         Padding="8,8,8,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                                    <Run Text=" nœuds"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Padding="8" BorderBrush="#1E1030" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource FC.AccentBtn}"
                                Content="+ Créer" FontSize="12" Margin="0,0,6,0"
                                Command="{Binding AddChainCommand}" HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="1" Style="{StaticResource FC.RedBtn}"
                                Content="✕" FontSize="13" Padding="10,8"
                                Command="{Binding DeleteChainCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" Background="#0D0818" BorderBrush="#1E1030" BorderThickness="0,0,0,1" Padding="20,0">
                <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        
                        <TextBlock x:Name="TbChainName" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#EDE9F7" VerticalAlignment="Center"
                                   Text="{Binding SelectedChain.Name, FallbackValue=''}"
                                   Cursor="IBeam" Margin="0,0,0,0"
                                   MouseLeftButtonDown="TbChainName_MouseLeftButtonDown"
                                   Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVis}}"/>
                        <TextBox x:Name="TbxChainName" FontSize="14" FontWeight="SemiBold"
                                 Foreground="#EDE9F7" Background="Transparent"
                                 BorderBrush="#7C3AED" BorderThickness="0,0,0,1"
                                 SelectionBrush="#7C3AED" CaretBrush="#7C3AED"
                                 VerticalAlignment="Center" Visibility="Collapsed"
                                 MinWidth="200"
                                 KeyDown="TbxChainName_KeyDown" LostFocus="TbxChainName_LostFocus"/>
                        <TextBlock Text="Sélectionnez ou créez une chaîne" FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                   Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVisInv}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource FC.Btn}" Content="+ Nœud" Margin="0,0,8,0"
                                Command="{Binding ShowAddNodePickerCommand}"
                                Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVis}}"/>
                        <Button Style="{StaticResource FC.GreenBtn}" Padding="14,8"
                                Content="▶  Exécuter" Command="{Binding ExecuteChainCommand}"
                                Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>

                <Border Margin="0,10,0,0"
                        Background="#0D0B1A" CornerRadius="8" Padding="12,7"
                        Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⌨ Raccourci:" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8B7AAE" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="TbxHotkey" Width="110" FontSize="11"
                                 Background="#1A1030" Foreground="#C4B5FD" BorderBrush="#3D256A"
                                 BorderThickness="1" Padding="6,3"
                                 Text="{Binding SelectedChain.TriggerHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                                 ToolTip="Ex: Ctrl+Alt+F1"/>
                        <CheckBox Grid.Column="4"
                                  IsChecked="{Binding SelectedChain.AutoTriggerEnabled, Mode=TwoWay}"
                                  Foreground="#8B7AAE" FontSize="11" VerticalAlignment="Center"
                                  Content="Auto (s)" ToolTip="Déclencher automatiquement à intervalle"/>
                        <TextBox Grid.Column="6" Width="60" FontSize="11"
                                 Background="#1A1030" Foreground="#C4B5FD" BorderBrush="#3D256A"
                                 BorderThickness="1" Padding="6,3"
                                 Text="{Binding SelectedChain.AutoTriggerIntervalSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Intervalle en secondes (min 10)"/>
                        <Button Grid.Column="8" Style="{StaticResource FC.AccentBtn}" Padding="10,4" FontSize="11"
                                Content="Appliquer" Command="{Binding ApplyTriggerCommand}"/>
                        <TextBlock Grid.Column="10" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Text="{Binding SelectedChain.TriggerSummary, FallbackValue=''}"/>
                    </Grid>
                </Border>
                </StackPanel>
            </Border>

            
            <Grid Grid.Row="1">

                
                <Grid.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Geometry>
                                    <EllipseGeometry RadiusX="0.8" RadiusY="0.8" Center="12,12"/>
                                </GeometryDrawing.Geometry>
                                <GeometryDrawing.Brush>
                                    <SolidColorBrush Color="#161628"/>
                                </GeometryDrawing.Brush>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVisInv}}">
                    <TextBlock Text="🔗" FontSize="56" HorizontalAlignment="Center"
                               Foreground="#12121E" Margin="0,0,0,12"
                               FontFamily="Segoe UI Emoji"/>
                    <TextBlock Text="Aucune chaîne sélectionnée" FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <Button Style="{StaticResource FC.AccentBtn}" Content="+ Créer une chaîne"
                            HorizontalAlignment="Center" Padding="20,10"
                            Command="{Binding AddChainCommand}"/>
                </StackPanel>

                
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasSelectedChain}" Value="True"/>
                                        <Condition Binding="{Binding NodeViewItems.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Style="{StaticResource FC.AccentBtn}" Command="{Binding ShowAddNodePickerCommand}" Padding="20,12" MinWidth="220">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Margin="0,0,10,0" FontSize="20"/>
                            <TextBlock Text="Ajouter un nœud pour commencer" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ScrollViewer x:Name="FlowScroll"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center" Padding="32,0"
                              PreviewMouseDown="FlowScroll_PreviewMouseDown"
                              PreviewMouseMove="FlowScroll_PreviewMouseMove"
                              PreviewMouseUp="FlowScroll_PreviewMouseUp"
                              Visibility="{Binding HasSelectedChain, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding NodeViewItems}" VerticalAlignment="Center"
                                  Tag="{Binding IsCompact, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Resources>

                            
                            <DataTemplate DataType="{x:Type models:PipelineStep}">
                                <Border CornerRadius="10"
                                        Background="#0E0E1C"
                                        BorderBrush="#1C1C38" BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Width"     Value="168"/>
                                            <Setter Property="MinHeight" Value="88"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                    <Setter Property="Width"     Value="148"/>
                                                    <Setter Property="MinHeight" Value="60"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="8"
                                                          ShadowDepth="0" Opacity="0.12"/>
                                    </Border.Effect>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectItemCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        
                                        <Border VerticalAlignment="Top" CornerRadius="10,10,0,0"
                                                Background="{Binding NodeTypeBrush, Converter={StaticResource HexToBrush}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Height" Value="3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                            <Setter Property="Height" Value="4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Margin" Value="10,10,10,10"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                            <Setter Property="Margin" Value="12,14,12,12"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            
                                            <Grid Margin="0,0,0,6">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    
                                                    <Border CornerRadius="6"
                                                            Background="{Binding NodeTypeBrush, Converter={StaticResource HexToBrush}}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Width" Value="22"/>
                                                                <Setter Property="Height" Value="22"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                                        <Setter Property="Width" Value="28"/>
                                                                        <Setter Property="Height" Value="28"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding NodeTypeIcon}"
                                                                   FontFamily="Segoe UI Emoji"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="White">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontSize" Value="10"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                                            <Setter Property="FontSize" Value="13"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <TextBlock Text="{Binding NodeTypeLabel}"
                                                               FontSize="8" FontWeight="Black"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                                <Button Style="{StaticResource FC.IconBtn}"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"
                                                        Command="{Binding DataContext.DeleteItemCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">?</Button>
                                            </Grid>

                                            
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="#C4B5FD" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="11"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                                <Setter Property="FontSize" Value="12"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            
                                            <TextBlock Text="{Binding SubTitle}" FontSize="9"
                                                       Foreground="{DynamicResource TextMutedBrush}" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="Margin" Value="0,2,0,0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>

                            
                            <DataTemplate DataType="{x:Type models:PipelineInsertMarker}">
                                <Grid VerticalAlignment="Center">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Width" Value="48"/>
                                            <Setter Property="Height" Value="48"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="False">
                                                    <Setter Property="Width" Value="60"/>
                                                    <Setter Property="Height" Value="60"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    
                                    <Rectangle Height="2" VerticalAlignment="Center"
                                               HorizontalAlignment="Left" Width="14"
                                               Fill="#1E1030"/>
                                    
                                    <Path VerticalAlignment="Center" HorizontalAlignment="Left"
                                          Margin="11,0,0,0"
                                          Data="M 0,-2 L 3,0 L 0,2"
                                          Stroke="#1E1030" StrokeThickness="1.5" Fill="#1E1030"/>
                                    
                                    <Button Style="{StaticResource FC.InsertBtn}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Command="{Binding DataContext.AddNodeAfterCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding AfterIndex}">+</Button>
                                    
                                    <Rectangle Height="2" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" Width="14"
                                               Fill="#1E1030"/>
                                </Grid>
                            </DataTemplate>

                        </ItemsControl.Resources>
                    </ItemsControl>
                </ScrollViewer>

                
                <Grid Background="#E0070711"
                      Visibility="{Binding IsAddNodePickerOpen, Converter={StaticResource BoolToVis}}">
                    <Border Background="#0E0E1C" CornerRadius="16" Padding="28,24"
                            MaxWidth="620" HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="#1A1030" BorderThickness="1">
                        
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.12"/>
                        </Border.Effect>
                        <StackPanel>
                            
                            <Grid Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="Choisir le type de nœud"
                                               FontSize="16" FontWeight="Bold" Foreground="#C4B5FD"/>
                                    <TextBlock Text="Sélectionnez l'action à insérer dans la chaîne"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Content="✕" Style="{StaticResource FC.IconBtn}" Padding="8,5"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Command="{Binding CloseAddNodePickerCommand}"/>
                            </Grid>

                            
                            <WrapPanel HorizontalAlignment="Center">

                                <Button Style="{StaticResource FC.TypeCard}"
                                        Command="{Binding AddNodeCommand}"
                                        CommandParameter="OpenApp">
                                    <StackPanel>
                                        <TextBlock Text="🚀" FontSize="26" HorizontalAlignment="Center"
                                                   Foreground="#7C3AED" FontFamily="Segoe UI Emoji"
                                                   Margin="0,4,0,6"/>
                                        <TextBlock Text="Ouvrir App" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#8B7AAE" HorizontalAlignment="Center"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="Lancer un .exe" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource FC.TypeCard}"
                                        Command="{Binding AddNodeCommand}"
                                        CommandParameter="CloseApp">
                                    <StackPanel>
                                        <TextBlock Text="⛔" FontSize="26" HorizontalAlignment="Center"
                                                   Foreground="#F97316" FontFamily="Segoe UI Emoji"
                                                   Margin="0,4,0,6"/>
                                        <TextBlock Text="Fermer App" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#8B7AAE" HorizontalAlignment="Center"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="Fermeture propre" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource FC.TypeCard}"
                                        Command="{Binding AddNodeCommand}"
                                        CommandParameter="RunCommand">
                                    <StackPanel>
                                        <TextBlock Text="⌨" FontSize="26" HorizontalAlignment="Center"
                                                   Foreground="#C4B5FD" FontFamily="Segoe UI Emoji"
                                                   Margin="0,4,0,6"/>
                                        <TextBlock Text="Commande" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#8B7AAE" HorizontalAlignment="Center"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="cmd / PowerShell" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource FC.TypeCard}"
                                        Command="{Binding AddNodeCommand}"
                                        CommandParameter="KillProcess">
                                    <StackPanel>
                                        <TextBlock Text="⚡" FontSize="26" HorizontalAlignment="Center"
                                                   Foreground="#EF4444" FontFamily="Segoe UI Emoji"
                                                   Margin="0,4,0,6"/>
                                        <TextBlock Text="Tuer Processus" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#8B7AAE" HorizontalAlignment="Center"
                                                   Margin="0,0,0,3"/>
                                        <TextBlock Text="Forcer fermeture" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource FC.TypeCard}"
                                        Command="{Binding AddNodeCommand}"
                                        CommandParameter="Delay">
                                    <StackPanel>
