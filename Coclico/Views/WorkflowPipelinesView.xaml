                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Texte à copier" FontSize="10" Foreground="#4A3870" Margin="0,0,0,5"/>
                                <Border Background="#0E0E1C" CornerRadius="6" Margin="0,0,0,16">
                                    <TextBox Text="{Binding ClipboardText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" Foreground="#7DD3FC"
                                             BorderThickness="0" Padding="10,8" FontSize="12"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinLines="3"/>
                                </Border>
                            </StackPanel>


                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NodeType}" Value="Screenshot">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Dossier de sauvegarde (vide = Images)" FontSize="10" Foreground="#4A3870" Margin="0,0,0,5"/>
                                <Border Background="#0E0E1C" CornerRadius="6" Margin="0,0,0,16">
                                    <TextBox Text="{Binding ScreenshotPath, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" Foreground="#C4B5FD"
                                             BorderThickness="0" Padding="10,8" FontSize="10"
                                             FontFamily="Consolas" ToolTip="Ex: C:\Captures"/>
                                </Border>
                            </StackPanel>


                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NodeType}" Value="SendKeys">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Touches à envoyer (syntaxe SendKeys)" FontSize="10" Foreground="#4A3870" Margin="0,0,0,5"/>
                                <Border Background="#0E0E1C" CornerRadius="6" Margin="0,0,0,16">
                                    <TextBox Text="{Binding SendKeysText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" Foreground="#C4B5FD"
                                             BorderThickness="0" Padding="10,8" FontSize="12"
                                             ToolTip="Ex: ^c (Ctrl+C), {ENTER}, %{F4}"/>
                                </Border>
                            </StackPanel>


                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NodeType}" Value="TriggerShortcut">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Combinaison de touches" FontSize="10" Foreground="#4A3870" Margin="0,0,0,5"/>
                                <Border Background="#0E0E1C" CornerRadius="6" Margin="0,0,0,8">
                                    <TextBox Text="{Binding TriggerShortcutKeys, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" Foreground="#C4B5FD"
                                             BorderThickness="0" Padding="10,8" FontSize="12"
                                             ToolTip="Ex: Ctrl+Alt+F1  •  Win+D  •  Ctrl+Shift+S"/>
                                </Border>
                                <TextBlock FontSize="9" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,16" TextWrapping="Wrap"
                                           Text="Touches supportées : Ctrl, Alt, Shift, Win, F1-F12, A-Z, Esc, Enter, Tab, Space, Del, Home, End, PageUp, PageDown, Left, Right, Up, Down"/>
                            </StackPanel>


                            <Button Style="{StaticResource FC.RedBtn}"
                                    HorizontalAlignment="Stretch" FontSize="12" Padding="0,10"
                                    Content="🗑  Supprimer ce nœud"
                                    Command="{Binding DataContext.DeleteItemCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                
                <Grid Background="#BB090910"
                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="44" HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Emoji"/>
                        <TextBlock Text="{Binding BusyMessage}" FontSize="14" Foreground="#C4B5FD"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</UserControl>

