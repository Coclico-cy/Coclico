<UserControl x:Class="Coclico.Views.RuleSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewModels="clr-namespace:Coclico.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgBaseBrush}" d:DesignHeight="200" d:DesignWidth="400">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource RuleDialog_Title}" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
        <ComboBox Grid.Row="1" x:Name="RuleComboBox" SelectedIndex="0" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource PrimaryButton}" x:Name="BtnOk"
                    Content="{DynamicResource RuleDialog_OK}" Margin="0,0,8,0"
                    Padding="20,8" Click="BtnOk_Click"/>
            <Button Style="{StaticResource GhostButton}" x:Name="BtnCancel"
                    Content="{DynamicResource RuleDialog_Cancel}"
                    Padding="20,8" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

