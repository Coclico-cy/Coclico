<UserControl x:Class="Coclico.Views.ScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:viewModels="clr-namespace:Coclico.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgBaseBrush}" d:DesignHeight="800" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance viewModels:ScannerViewModel}">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PageRoot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>
                    <DoubleAnimation Storyboard.TargetName="PageSlide"
                                     Storyboard.TargetProperty="Y"
                                     From="14" To="0" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        
        <Style x:Key="SourceBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="{StaticResource CornerPill}"/>
            <Setter Property="Padding"      Value="8,3"/>
            <Setter Property="Background"   Value="#14FFFFFF"/>
        </Style>
        
        <Style x:Key="ScanRow" TargetType="Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="16,11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgPanelBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="PageRoot" Margin="32,28,32,0" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PageSlide" Y="0"/>
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="{DynamicResource Menu_Scanner}" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{DynamicResource Scanner_Subtitle}" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            
            <Border CornerRadius="{DynamicResource CornerPill}"
                    Padding="12,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#14FFFFFF" Offset="0"/>
                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#2A1848" Opacity="0.5"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel Orientation="Horizontal">
                    <ui:ProgressRing IsIndeterminate="True" Width="14" Height="14" Margin="0,0,8,0"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               FontFamily="Consolas, Courier New"/>
                </StackPanel>
            </Border>

            
            <ui:TextBox Grid.Column="1" x:Name="SearchBox"
                        PlaceholderText="{DynamicResource Scanner_SearchPlaceholder}"
                        TextChanged="SearchBox_TextChanged"/>
        </Grid>

        
        <Border Grid.Row="2" CornerRadius="{DynamicResource CornerCard}"
                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                Margin="0,0,0,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0D0818" Offset="0"/>
                    <GradientStop Color="#08050F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>

                
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Programs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    
                    <Border Width="72" Height="72" CornerRadius="36"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A0A30" Offset="0"/>
                                <GradientStop Color="#120B24" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4A1FA8" Offset="0"/>
                                <GradientStop Color="#BE185D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <ui:SymbolIcon Symbol="SearchSquare24" FontSize="28"
                                       Foreground="{DynamicResource TextAccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding ScanCommand}"
                            Padding="28,12" MinWidth="200" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="SearchSquare24" Margin="0,0,8,0" FontSize="16"/>
                            <TextBlock Text="{DynamicResource Scanner_Scan}"
                                       FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{DynamicResource Scanner_EmptySubtitle}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Programs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1" Padding="16,9">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#14FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="APPLICATION"
                                       FontSize="9" FontWeight="Black"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="SOURCE"
                                       FontSize="9" FontWeight="Black"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Grid.Column="3" Text="VERSION"
                                       FontSize="9" FontWeight="Black"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="True">
                        <ItemsControl x:Name="ResultsList"
                                      ItemsSource="{Binding Programs}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ScanRow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            
                                            <Border Width="32" Height="32" CornerRadius="9"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#2A0A50" Offset="0"/>
                                                        <GradientStop Color="#1A0838" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Name, Converter={StaticResource FirstCharConverter}}"
                                                           FontSize="14" FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextAccentBrush}"/>
                                            </Border>

                                            
                                            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Publisher, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding InstallPath, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            
                                            <Border Grid.Column="2" Style="{StaticResource SourceBadge}"
                                                    VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Source}" FontSize="9"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontFamily="Consolas, Courier New"/>
                                            </Border>

                                            
                                            <TextBlock Grid.Column="3" Text="{Binding Version}"
                                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                       FontFamily="Consolas, Courier New"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                
                <Border CornerRadius="{DynamicResource CornerCard}"
                        Background="#E808050F"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="44" Height="44"
                                         Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Scanner_Scanning}"
                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>

