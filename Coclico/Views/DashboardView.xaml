<UserControl x:Class="Coclico.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Coclico.ViewModels"
             d:DesignHeight="800" d:DesignWidth="1000"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BgBaseBrush}">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <!-- ═══════════════════════════════════════════════
         Entrance animation — staggered fade + slide up
    ═══════════════════════════════════════════════ -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.45"
                                     EasingFunction="{x:Null}"/>
                    <DoubleAnimation Storyboard.TargetName="ContentSlide"
                                     Storyboard.TargetProperty="Y"
                                     From="18" To="0" Duration="0:0:0.40">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>

        
        <Style x:Key="GlowProgressBar" TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="Maximum"         Value="100"/>
            <Setter Property="Background"      Value="#12082A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="2"
                                Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}">
                            <Border x:Name="PART_Indicator" CornerRadius="2"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding RelativeSource={RelativeSource AncestorType=ProgressBar}, Path=Foreground}"
                                                      BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="InstrumentCard" TargetType="Border">
            <Setter Property="CornerRadius"    Value="{DynamicResource CornerCard}"/>
            <Setter Property="Padding"         Value="22,18"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#3A2860"/>
            <Setter Property="Margin"     Value="2,0,0,14"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        
        <Style x:Key="GuideCard" TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
            <Setter Property="Background"      Value="{DynamicResource BgPanelBrush}"/>
            <Setter Property="CornerRadius"    Value="{DynamicResource CornerCard}"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        
        <Style x:Key="GuideTip" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="CornerRadius"    Value="{DynamicResource CornerSmall}"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        
        <Style x:Key="ChangeItem" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="CornerRadius"    Value="{DynamicResource CornerSmall}"/>
            <Setter Property="Padding"         Value="0,0,14,0"/>
            <Setter Property="Margin"          Value="0,0,0,6"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource BgBaseBrush}">

        <StackPanel x:Name="MainContent"
                    Margin="32,28,32,40"
                    Opacity="0">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="ContentSlide" Y="0"/>
            </StackPanel.RenderTransform>

            <!-- ═══════════════════════════════════
                 HEADER — title + live indicator
            ═══════════════════════════════════ -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Menu_Dashboard}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{DynamicResource Dashboard_Subtitle}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                
                <Border Grid.Column="1"
                        CornerRadius="{DynamicResource CornerPill}"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#10D9A0" Offset="0"/>
                            <GradientStop Color="#0EA472" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#06231A" Offset="0"/>
                            <GradientStop Color="#081F16" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="LiveDot" Width="6" Height="6"
                                 Fill="#10D9A0" VerticalAlignment="Center"
                                 Margin="0,0,7,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.15"
                                                             Duration="0:0:0.9"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="LIVE" FontSize="9" FontWeight="Black"
                                   Foreground="#10D9A0" VerticalAlignment="Center"
                                   FontFamily="Consolas, Courier New"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════
                 SECTION LABEL — System Vitals
            ═══════════════════════════════════ -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource SectionLabel}"
                           Margin="2,0,10,0"
                           VerticalAlignment="Center"
                           Text="{DynamicResource Dashboard_SysLive}"/>
                <Border Grid.Column="1" Height="1" VerticalAlignment="Center" Margin="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2A1848" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════
                 INSTRUMENT GRID — 2×2, each card has a colored identity
            ═══════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                
                <Border Grid.Column="0" Style="{StaticResource InstrumentCard}" Margin="0,0,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#190E30" Offset="0"/>
                            <GradientStop Color="#120B24" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#4A2280" Offset="0"/>
                            <GradientStop Color="#2A1050" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#7C3AED" BlurRadius="22"
                                          Opacity="0.18" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="32" Height="32" CornerRadius="9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B0764" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#7C3AED" BlurRadius="10"
                                                      Opacity="0.5" ShadowDepth="0"/>
                                </Border.Effect>
                                <ui:SymbolIcon Symbol="Pulse24" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="CPU" FontSize="9" FontWeight="Black"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{DynamicResource Dashboard_CPUSub}"
                                           FontSize="8" Foreground="{DynamicResource TextMutedBrush}"
                                           Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        
                        <TextBlock Grid.Row="1"
                                   Text="{Binding CpuUsageText}"
                                   FontSize="34" FontWeight="Black"
                                   Foreground="#C4B5FD"
                                   FontFamily="Consolas, Courier New, monospace"
                                   Margin="0,0,0,12"/>

                        
                        <ProgressBar Grid.Row="2"
                                     Style="{StaticResource GlowProgressBar}"
                                     Value="{Binding CpuUsage, Mode=OneWay}"
                                     Foreground="#7C3AED"/>
                    </Grid>
                </Border>

                
                <Border Grid.Column="2" Style="{StaticResource InstrumentCard}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#091520" Offset="0"/>
                            <GradientStop Color="#06101A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0E4A70" Offset="0"/>
                            <GradientStop Color="#083050" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#0284C7" BlurRadius="22"
                                          Opacity="0.18" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="32" Height="32" CornerRadius="9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0C4A6E" Offset="0"/>
                                        <GradientStop Color="#0284C7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0284C7" BlurRadius="10"
                                                      Opacity="0.5" ShadowDepth="0"/>
                                </Border.Effect>
                                <ui:SymbolIcon Symbol="Storage24" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="RAM" FontSize="9" FontWeight="Black"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding RamUsageText}"
                                           FontSize="8" Foreground="{DynamicResource TextMutedBrush}"
                                           Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1">
                            <TextBlock.FontFamily>Consolas, Courier New, monospace</TextBlock.FontFamily>
                            <TextBlock.FontSize>34</TextBlock.FontSize>
                            <TextBlock.FontWeight>Black</TextBlock.FontWeight>
                            <TextBlock.Foreground>#7DD3FC</TextBlock.Foreground>
                            <TextBlock.Margin>0,0,0,12</TextBlock.Margin>
                            <Run Text="{Binding RamUsagePercent, StringFormat={}{0:F0}, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>

                        <ProgressBar Grid.Row="2"
                                     Style="{StaticResource GlowProgressBar}"
                                     Value="{Binding RamUsagePercent, Mode=OneWay}"
                                     Foreground="#0284C7"/>
                    </Grid>
                </Border>

                
                <Border Grid.Column="4" Style="{StaticResource InstrumentCard}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#081A10" Offset="0"/>
                            <GradientStop Color="#05120A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0D4A28" Offset="0"/>
                            <GradientStop Color="#083018" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#10D9A0" BlurRadius="22"
                                          Opacity="0.14" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="32" Height="32" CornerRadius="9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#14532D" Offset="0"/>
                                        <GradientStop Color="#10D9A0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#10D9A0" BlurRadius="10"
                                                      Opacity="0.5" ShadowDepth="0"/>
                                </Border.Effect>
                                <ui:SymbolIcon Symbol="HardDrive24" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Dashboard_Disk}"
                                           FontSize="9" FontWeight="Black"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding DiskUsageText}"
                                           FontSize="8" Foreground="{DynamicResource TextMutedBrush}"
                                           Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1">
                            <TextBlock.FontFamily>Consolas, Courier New, monospace</TextBlock.FontFamily>
                            <TextBlock.FontSize>34</TextBlock.FontSize>
                            <TextBlock.FontWeight>Black</TextBlock.FontWeight>
                            <TextBlock.Foreground>#6EE7B7</TextBlock.Foreground>
                            <TextBlock.Margin>0,0,0,12</TextBlock.Margin>
                            <Run Text="{Binding DiskUsagePercent, StringFormat={}{0:F0}, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>

                        <ProgressBar Grid.Row="2"
                                     Style="{StaticResource GlowProgressBar}"
                                     Value="{Binding DiskUsagePercent, Mode=OneWay}"
                                     Foreground="#10D9A0"/>
                    </Grid>
                </Border>

                
                <Border Grid.Column="6" Style="{StaticResource InstrumentCard}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A0E05" Offset="0"/>
                            <GradientStop Color="#120A03" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#7C3D12" Offset="0"/>
                            <GradientStop Color="#4A2208" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="#F97316" BlurRadius="22"
                                          Opacity="0.14" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="32" Height="32" CornerRadius="9">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C2D12" Offset="0"/>
                                        <GradientStop Color="#F97316" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#F97316" BlurRadius="10"
                                                      Opacity="0.5" ShadowDepth="0"/>
                                </Border.Effect>
                                <ui:SymbolIcon Symbol="Timer24" FontSize="14" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="UPTIME" FontSize="9" FontWeight="Black"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding ProcessCount, StringFormat={}{0} proc.}"
                                           FontSize="8" Foreground="{DynamicResource TextMutedBrush}"
                                           Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding UptimeText}"
                                   FontSize="24" FontWeight="Black"
                                   Foreground="#FED7AA"
                                   FontFamily="Consolas, Courier New, monospace"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        
                        <Border Grid.Row="2" Height="5" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F97316" Offset="0"/>
                                    <GradientStop Color="#FBBF24" Offset="0.6"/>
                                    <GradientStop Color="#FDE68A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

            </Grid>

            <!-- ═══════════════════════════════════
                 APPS OVERVIEW BANNER
            ═══════════════════════════════════ -->
            <Border Margin="0,0,0,28" CornerRadius="{DynamicResource CornerCard}"
                    Padding="24,16" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#13082A" Offset="0"/>
                        <GradientStop Color="#1A0E38" Offset="0.5"/>
                        <GradientStop Color="#13082A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A1FA8" Offset="0"/>
                        <GradientStop Color="#BE185D" Offset="0.5"/>
                        <GradientStop Color="#4A1FA8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect Color="#7C3AED" BlurRadius="28"
                                      Opacity="0.12" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Dashboard_AppsSection}"
                                   FontSize="9" FontWeight="Black"
                                   Foreground="#5A3090" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding InstalledAppsCount}"
                                       FontSize="32" FontWeight="Black"
                                       Foreground="{DynamicResource TextAccentBrush}"
                                       FontFamily="Consolas, Courier New, monospace"
                                       VerticalAlignment="Bottom"/>
                            <TextBlock Text="{DynamicResource Dashboard_SoftwareDetected}"
                                       VerticalAlignment="Bottom"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="8,0,0,5"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" VerticalAlignment="Center">
                        <Border Width="52" Height="52" CornerRadius="14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4A1FA8" Offset="0"/>
                                    <GradientStop Color="#BE185D" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#BE185D" BlurRadius="16"
                                                  Opacity="0.45" ShadowDepth="0"/>
                            </Border.Effect>
                            <ui:SymbolIcon Symbol="Apps24" FontSize="22" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════
                 SECTION LABEL — Changelog
            ═══════════════════════════════════ -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Style="{StaticResource SectionLabel}"
                           Margin="2,0,10,0" VerticalAlignment="Center"
                           Text="{DynamicResource Dashboard_Changelog}"/>
                <Border Grid.Column="1" Height="1" VerticalAlignment="Center" Margin="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2A1848" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════
                 CHANGELOG PANEL
            ═══════════════════════════════════ -->
            <Border Margin="0,0,0,28"
                    Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource CornerCard}"
                    Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    
                    <Border Grid.Column="0" Margin="0,0,28,0" VerticalAlignment="Top">
                        <StackPanel>
                            <Border CornerRadius="{DynamicResource CornerNode}"
                                    Padding="20,14" HorizontalAlignment="Center"
                                    Margin="0,0,0,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4A1FA8" Offset="0"/>
                                        <GradientStop Color="#BE185D" Offset="0.6"/>
                                        <GradientStop Color="#F97316" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#7C3AED" BlurRadius="18"
                                                      Opacity="0.4" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="v1.0.4" FontSize="20" FontWeight="Black"
                                               Foreground="White" HorizontalAlignment="Center"
                                               FontFamily="Consolas, Courier New, monospace"/>
                                    <TextBlock Text="STABLE" FontSize="8" FontWeight="Black"
                                               Foreground="#EDE9F7" HorizontalAlignment="Center"
                                               Margin="0,4,0,0" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Latest" FontSize="9"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Consolas, Courier New, monospace"/>
                        </StackPanel>
                    </Border>

                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource Dashboard_ChangelogTitle}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,14"/>

                        
                        <Border Style="{StaticResource ChangeItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="4,0,0,4"
                                        Background="{DynamicResource SuccessBrush}"/>
                                <StackPanel Grid.Column="1" Margin="14,11,0,11">
                                    <TextBlock Text="{DynamicResource Dashboard_Change1_Title}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextAccentBrush}"/>
                                    <TextBlock Text="{DynamicResource Dashboard_Change1_Desc}"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
