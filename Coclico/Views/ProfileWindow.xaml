<Window x:Class="Coclico.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Profile_Title}" Height="500" Width="350"
        Icon="/Resources/icone/plage.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" MouseDown="Window_MouseDown">
    <Border Margin="10" Background="{DynamicResource BgCardBrush}" CornerRadius="{StaticResource CornerNode}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.25"/>
        </Border.Effect>
        <Grid>
            <ui:Button Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Appearance="Transparent" Padding="6">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" Opacity="0.5"/>
            </ui:Button>

            <StackPanel Margin="32">
                <Grid HorizontalAlignment="Left" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid MouseLeftButtonUp="Avatar_Click" Cursor="Hand" ToolTip="{DynamicResource Profile_ChangeAvatar}">
                        <Ellipse Width="80" Height="80" Fill="#10FFFFFF" Stroke="#1E1030" StrokeThickness="1"/>
                        <TextBlock x:Name="UserInitialText" Text="M" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="32" FontWeight="Bold" Opacity="0.2"/>
                        <Image x:Name="UserAvatarImage" Width="80" Height="80" Stretch="UniformToFill">
                            <Image.Clip>
                                <EllipseGeometry RadiusX="40" RadiusY="40" Center="40,40"/>
                            </Image.Clip>
                        </Image>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock x:Name="UserNameText" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="AccountTypeText" Text="{DynamicResource Profile_AccountType}" Opacity="0.4" FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock x:Name="UserEmailText" Foreground="{DynamicResource SecondaryBrush}" FontSize="12" Margin="0,8,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}" Margin="0,0,0,32"/>

                <TextBlock Text="{DynamicResource Profile_SystemIdentity}" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,16"/>

                <ui:Button Click="OpenInfo_Click" Appearance="Transparent" HorizontalAlignment="Stretch" Margin="0,0,0,8" Padding="12">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="Person24" FontSize="16" Opacity="0.6" Margin="0,0,16,0"/>
                        <TextBlock Text="{DynamicResource Profile_IdentityDetails}" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ui:SymbolIcon Symbol="ChevronRight24" Grid.Column="2" FontSize="12" Opacity="0.3"/>
                    </Grid>
                </ui:Button>

                <ui:Button Click="OpenAccounts_Click" Appearance="Transparent" HorizontalAlignment="Stretch" Margin="0,0,0,8" Padding="12">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="ArrowSync24" FontSize="16" Opacity="0.6" Margin="0,0,16,0"/>
                        <TextBlock Text="{DynamicResource Profile_AccountSync}" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ui:SymbolIcon Symbol="ChevronRight24" Grid.Column="2" FontSize="12" Opacity="0.3"/>
                    </Grid>
                </ui:Button>

                <Border Background="{DynamicResource BgPanelBrush}" CornerRadius="{StaticResource CornerSmall}"
                        Padding="16" Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ShieldCheckmark24" Foreground="{DynamicResource SuccessBrush}" FontSize="16"/>
                        <TextBlock Text="{DynamicResource Profile_SystemStable}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12" Opacity="0.6" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>

