<Window x:Class="Coclico.Views.SplashWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       WindowStyle="None"
       AllowsTransparency="True"
       Background="Transparent"
       Width="600" Height="320"
       WindowStartupLocation="CenterScreen"
       ResizeMode="NoResize"
       Topmost="True"
       ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SplashProgress" TargetType="ProgressBar">
            <Setter Property="Height"          Value="3"/>
            <Setter Property="Minimum"         Value="0"/>
            <Setter Property="Maximum"         Value="100"/>
            <Setter Property="Background"      Value="#1E1030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="2" Background="{TemplateBinding Background}">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6B2FD9" Offset="0"/>
                                            <GradientStop Color="#BE185D" Offset="0.5"/>
                                            <GradientStop Color="#F97316" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BackEase x:Key="SplashBack" EasingMode="EaseOut" Amplitude="0.35"/>
        <CubicEase x:Key="SplashEase" EasingMode="EaseOut"/>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ContentGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.38"
                                     BeginTime="0:0:0.05"
                                     EasingFunction="{StaticResource SplashEase}"/>
                    <ThicknessAnimation Storyboard.TargetName="ContentGrid"
                                        Storyboard.TargetProperty="Margin"
                                        From="44,48,44,28" To="44,28,44,28"
                                        Duration="0:0:0.45"
                                        BeginTime="0:0:0.05"
                                        EasingFunction="{StaticResource SplashEase}"/>
                    <DoubleAnimation Storyboard.TargetName="LogoScaleX"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.72" To="1"
                                     Duration="0:0:0.50"
                                     BeginTime="0:0:0.08"
                                     EasingFunction="{StaticResource SplashBack}"/>
                    <DoubleAnimation Storyboard.TargetName="LogoScaleY"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.72" To="1"
                                     Duration="0:0:0.50"
                                     BeginTime="0:0:0.08"
                                     EasingFunction="{StaticResource SplashBack}"/>
                    <DoubleAnimation Storyboard.TargetName="LogoBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.30"
                                     BeginTime="0:0:0.08"/>
                    <DoubleAnimation Storyboard.TargetName="TitleStack"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.35"
                                     BeginTime="0:0:0.22"
                                     EasingFunction="{StaticResource SplashEase}"/>
                    <ThicknessAnimation Storyboard.TargetName="TitleStack"
                                        Storyboard.TargetProperty="Margin"
                                        From="0,12,0,0" To="0,0,0,0"
                                        Duration="0:0:0.40"
                                        BeginTime="0:0:0.22"
                                        EasingFunction="{StaticResource SplashEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ProgressArea"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.30"
                                     BeginTime="0:0:0.35"
                                     EasingFunction="{StaticResource SplashEase}"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Border CornerRadius="20" ClipToBounds="True" Background="#08050F"
                BorderBrush="#2A1848" BorderThickness="1">
            <Grid>
                <Ellipse Width="500" Height="300" Opacity="0.06"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Ellipse Width="250" Height="250" Opacity="0.04"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,20,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#F97316" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Border Height="2" VerticalAlignment="Top" CornerRadius="20,20,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#6B2FD9"     Offset="0.2"/>
                            <GradientStop Color="#BE185D"     Offset="0.5"/>
                            <GradientStop Color="#F97316"     Offset="0.8"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid x:Name="ContentGrid" Margin="44,28,44,28" Opacity="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border x:Name="LogoBorder"
                                    Width="64" Height="64" CornerRadius="18" Margin="0,0,20,0"
                                    VerticalAlignment="Center" Background="#130B20"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.Effect>
                                    <DropShadowEffect Color="#7C3AED" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="LogoScaleX" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Image Source="/Resources/icone/plage.png"
                                       Width="48" Height="48"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <Border x:Name="LogoBorder2" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="LogoScaleY" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <StackPanel x:Name="TitleStack" VerticalAlignment="Center" Opacity="0">
                                    <TextBlock Text="Coclico" FontSize="34" FontWeight="Black"
                                               Foreground="#EDE9F7" FontFamily="Segoe UI"/>
                                    <TextBlock Text="Gestionnaire système intelligent"
                                               FontSize="11" Foreground="#5A4080" Margin="0,4,0,0"/>
                                    <Border Background="#130B20" BorderBrush="#2A1848"
                                            BorderThickness="1" CornerRadius="10"
                                            Padding="10,4" HorizontalAlignment="Left" Margin="0,8,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                                        <GradientStop Color="#DB2777" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="v1.0.3  BETA"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="#5A4080"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="ProgressArea" Grid.Row="1" Opacity="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="›" FontSize="12" Foreground="#7C3AED"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStatus" Text="Initialisation..."
                                       FontSize="11" Foreground="#5A4080"
                                       FontFamily="Consolas, Courier New, monospace"/>
                        </StackPanel>

                        <ProgressBar x:Name="PbProgress"
                                     Style="{StaticResource SplashProgress}"
                                     Value="0"/>

                        <Grid Margin="0,10,0,0">
                            <TextBlock Text="© 2026 Coclico" FontSize="9"
                                       Foreground="#2A1848"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtHint" Text="Chargement en cours…"
                                       FontSize="9" Foreground="#2A1848"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>

