<Application x:Class="Coclico.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Coclico.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <Application.Resources>
      <ResourceDictionary>
          <ResourceDictionary.MergedDictionaries>
              <ui:ThemesDictionary Theme="Dark" />
              <ui:ControlsDictionary />
          </ResourceDictionary.MergedDictionaries>

          <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
          <converters:BooleanToVisibilityInvertedConverter x:Key="BooleanToVisibilityInvertedConverter"/>
          <converters:FileIconToImageSourceConverter x:Key="FileIconToImageSourceConverter"/>
          <converters:HexToBrushConverter x:Key="HexToBrush"/>
          <converters:StringFirstCharConverter x:Key="FirstCharConverter"/>

          <Color x:Key="AccentPrimary">#7C3AED</Color>
          <Color x:Key="AccentSecondary">#DB2777</Color>
          <Color x:Key="AccentSuccess">#10D9A0</Color>

          <sys:Double x:Key="GlobalFontSize">13</sys:Double>
          <Thickness x:Key="CardPadding">20,18,20,18</Thickness>
          <Thickness x:Key="CardPadding_Compact">14,12,14,12</Thickness>

          <Duration x:Key="AnimFast">0:0:0.15</Duration>
          <Duration x:Key="AnimMed">0:0:0.25</Duration>
          <Duration x:Key="AnimSlow">0:0:0.40</Duration>

          <CornerRadius x:Key="CornerCard">14</CornerRadius>
          <CornerRadius x:Key="CornerBtn">10</CornerRadius>
          <CornerRadius x:Key="CornerSmall">8</CornerRadius>
          <CornerRadius x:Key="CornerPill">999</CornerRadius>
          <CornerRadius x:Key="CornerNode">12</CornerRadius>

          <!-- ── Backgrounds ── -->
          <SolidColorBrush x:Key="BgBaseBrush"        Color="#07040E"/>
          <SolidColorBrush x:Key="BgPanelBrush"       Color="#0A0617"/>
          <SolidColorBrush x:Key="BgCardBrush"        Color="#0F0B1C"/>
          <SolidColorBrush x:Key="BgElevatedBrush"    Color="#161030"/>
          <SolidColorBrush x:Key="BgHoverBrush"       Color="#1C1438"/>

          <!-- ── Borders ── -->
          <SolidColorBrush x:Key="BorderSubtleBrush"  Color="#160F28"/>
          <SolidColorBrush x:Key="BorderDefaultBrush" Color="#231844"/>
          <SolidColorBrush x:Key="BorderStrongBrush"  Color="#382060"/>

          <!-- ── Text ── -->
          <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F0EBF8"/>
          <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9585BB"/>
          <SolidColorBrush x:Key="TextMutedBrush"     Color="#6B5CA8"/>
          <SolidColorBrush x:Key="TextHintBrush"      Color="#3A2860"/>
          <SolidColorBrush x:Key="TextAccentBrush"    Color="#C9BBFF"/>

          <SolidColorBrush x:Key="PrimaryBrush"    Color="{DynamicResource AccentPrimary}"/>
          <SolidColorBrush x:Key="SecondaryBrush"  Color="{DynamicResource AccentSecondary}"/>
          <SolidColorBrush x:Key="SuccessBrush"    Color="{DynamicResource AccentSuccess}"/>
          <SolidColorBrush x:Key="CyanBrush"       Color="#22D3EE"/>
          <SolidColorBrush x:Key="WarnBrush"       Color="#F59E0B"/>
          <SolidColorBrush x:Key="DangerBrush"     Color="#EF4444"/>

          <SolidColorBrush x:Key="NodeStartBrush"   Color="#10D9A0"/>
          <SolidColorBrush x:Key="NodeActionBrush"  Color="#7C3AED"/>
          <SolidColorBrush x:Key="NodeEndBrush"     Color="#EF4444"/>
          <SolidColorBrush x:Key="NodeCmdBrush"     Color="#F59E0B"/>
          <SolidColorBrush x:Key="NodeWaitBrush"    Color="#22D3EE"/>

          <SolidColorBrush x:Key="OverlayLight"      Color="#0EFFFFFF"/>
          <SolidColorBrush x:Key="OverlayMid"        Color="#08FFFFFF"/>
          <SolidColorBrush x:Key="OverlayFaint"      Color="#05FFFFFF"/>
          <SolidColorBrush x:Key="OverlayDark"       Color="#F008050F"/>
          <SolidColorBrush x:Key="OverlayDarkStrong" Color="#F004020A"/>

          <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#7C3AED" Offset="0"/>
              <GradientStop Color="#DB2777" Offset="1"/>
          </LinearGradientBrush>

          <LinearGradientBrush x:Key="PrimaryGradientDiag" StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#6B2FD9" Offset="0"/>
              <GradientStop Color="#BE185D" Offset="0.6"/>
              <GradientStop Color="#F97316" Offset="1"/>
          </LinearGradientBrush>

          <LinearGradientBrush x:Key="FoxGradient" StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#6B2FD9" Offset="0"/>
              <GradientStop Color="#BE185D" Offset="0.5"/>
              <GradientStop Color="#F97316" Offset="1"/>
          </LinearGradientBrush>

          <LinearGradientBrush x:Key="FoxGradientDiag" StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#4A1FA8" Offset="0"/>
              <GradientStop Color="#BE185D" Offset="0.55"/>
              <GradientStop Color="#F97316" Offset="1"/>
          </LinearGradientBrush>

          <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#059669" Offset="0"/>
              <GradientStop Color="#10D9A0" Offset="1"/>
          </LinearGradientBrush>

          <SolidColorBrush x:Key="NavGlowBrush" Color="#00000000"/>

          <CubicEase x:Key="EaseOut"   EasingMode="EaseOut"/>
          <CubicEase x:Key="EaseIn"    EasingMode="EaseIn"/>
          <CubicEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
          <BackEase  x:Key="EaseBack"  EasingMode="EaseOut" Amplitude="0.4"/>

          <SolidColorBrush x:Key="AccentBrush"   Color="#7C3AED"/>
          <SolidColorBrush x:Key="WarningBrush"  Color="#F59E0B"/>

          <!-- Standard card — fond doux, bordure subtile -->
          <Style x:Key="SubtleCard" TargetType="Border">
              <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
              <Setter Property="BorderBrush"     Value="{DynamicResource BorderDefaultBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius"    Value="{StaticResource CornerCard}"/>
              <Setter Property="Padding"         Value="{DynamicResource CardPadding}"/>
              <Setter Property="Effect">
                  <Setter.Value>
                      <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="2" Opacity="0.28" Direction="270"/>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Elevated card — légèrement plus claire, ombre plus prononcée -->
          <Style x:Key="ElevatedCard" TargetType="Border">
              <Setter Property="Background"      Value="{DynamicResource BgElevatedBrush}"/>
              <Setter Property="BorderBrush"     Value="{DynamicResource BorderStrongBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius"    Value="{StaticResource CornerCard}"/>
              <Setter Property="Padding"         Value="{DynamicResource CardPadding}"/>
              <Setter Property="Effect">
                  <Setter.Value>
                      <DropShadowEffect Color="#5B21B6" BlurRadius="28" ShadowDepth="0" Opacity="0.14"/>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Accent card — bordure violette lumineuse -->
          <Style x:Key="GlowCard" TargetType="Border">
              <Setter Property="Background"      Value="#120E24"/>
              <Setter Property="BorderBrush"     Value="{DynamicResource BorderStrongBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius"    Value="{StaticResource CornerCard}"/>
              <Setter Property="Padding"         Value="20,18"/>
              <Setter Property="Effect">
                  <Setter.Value>
                      <DropShadowEffect Color="#7C3AED" BlurRadius="20" ShadowDepth="0" Opacity="0.12"/>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Terminal card — fond très sombre, style monospace -->
          <Style x:Key="TerminalCard" TargetType="Border">
              <Setter Property="Background"      Value="#05030A"/>
              <Setter Property="BorderBrush"     Value="{DynamicResource BorderSubtleBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius"    Value="{StaticResource CornerSmall}"/>
              <Setter Property="Padding"         Value="16,12"/>
          </Style>

          <!-- Premium card — dégradé AI/accent avec glow -->
          <Style x:Key="PremiumCard" TargetType="Border">
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius"    Value="{StaticResource CornerCard}"/>
              <Setter Property="Padding"         Value="{DynamicResource CardPadding}"/>
              <Setter Property="Background">
                  <Setter.Value>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                          <GradientStop Color="#140A30" Offset="0"/>
                          <GradientStop Color="#1A0D38" Offset="1"/>
                      </LinearGradientBrush>
                  </Setter.Value>
              </Setter>
              <Setter Property="BorderBrush">
                  <Setter.Value>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                          <GradientStop Color="#3D2070" Offset="0"/>
                          <GradientStop Color="#6B2060" Offset="1"/>
                      </LinearGradientBrush>
                  </Setter.Value>
              </Setter>
              <Setter Property="Effect">
                  <Setter.Value>
                      <DropShadowEffect Color="#7C3AED" BlurRadius="30" ShadowDepth="0" Opacity="0.18"/>
                  </Setter.Value>
              </Setter>
          </Style>

          <!-- Carte interactive avec glow au survol + élévation -->
          <Style x:Key="AnimatedCard" TargetType="Border">
              <Setter Property="Background"      Value="{DynamicResource BgCardBrush}"/>
              <Setter Property="BorderBrush"     Value="{DynamicResource BorderDefaultBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="CornerRadius"    Value="{StaticResource CornerCard}"/>
              <Setter Property="Padding"         Value="{DynamicResource CardPadding}"/>
              <Setter Property="Cursor"          Value="Hand"/>
              <Setter Property="Effect">
                  <Setter.Value>
                      <DropShadowEffect Color="#7C3AED" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                  </Setter.Value>
              </Setter>
              <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
              <Setter Property="RenderTransform">
                  <Setter.Value>
                      <ScaleTransform ScaleX="1" ScaleY="1"/>
                  </Setter.Value>
              </Setter>
              <Style.Triggers>
                  <EventTrigger RoutedEvent="Border.MouseEnter">
                      <BeginStoryboard>
                          <Storyboard>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               To="22" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               To="0.22" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.012" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.012" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                          </Storyboard>
                      </BeginStoryboard>
                  </EventTrigger>
                  <EventTrigger RoutedEvent="Border.MouseLeave">
                      <BeginStoryboard>
                          <Storyboard>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                               To="0" Duration="0:0:0.22"/>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                               To="0" Duration="0:0:0.22"/>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                          </Storyboard>
                      </BeginStoryboard>
                  </EventTrigger>
              </Style.Triggers>
          </Style>

          <Style x:Key="SectionLabel" TargetType="TextBlock">
              <Setter Property="FontSize"   Value="9.5"/>
              <Setter Property="FontWeight" Value="Black"/>
              <Setter Property="Foreground" Value="{DynamicResource TextHintBrush}"/>
              <Setter Property="Margin"     Value="2,0,0,14"/>
              <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
          </Style>

          <!-- Titre de section lisible (sous-titres de groupes de contenu) -->
          <Style x:Key="SectionTitle" TargetType="TextBlock">
              <Setter Property="FontSize"   Value="16"/>
              <Setter Property="FontWeight" Value="SemiBold"/>
              <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
              <Setter Property="Margin"     Value="0,0,0,4"/>
          </Style>

          <!-- Texte de description standard sous un titre -->
          <Style x:Key="DescText" TargetType="TextBlock">
              <Setter Property="FontSize"      Value="12"/>
              <Setter Property="Foreground"    Value="{DynamicResource TextSecondaryBrush}"/>
              <Setter Property="TextWrapping"  Value="Wrap"/>
              <Setter Property="LineHeight"    Value="18"/>
          </Style>

          <Style TargetType="TextBlock">
              <Setter Property="FontSize"   Value="{DynamicResource GlobalFontSize}"/>
              <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI Variable, Segoe UI, sans-serif"/>
              <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
              <Setter Property="RenderOptions.ClearTypeHint"  Value="Enabled"/>
          </Style>

          <Style x:Key="PrimaryButton" TargetType="Button">
              <Setter Property="Cursor"                     Value="Hand"/>
              <Setter Property="Foreground"                 Value="White"/>
              <Setter Property="FontWeight"                 Value="SemiBold"/>
              <Setter Property="Padding"                    Value="20,10"/>
              <Setter Property="BorderThickness"            Value="0"/>
              <Setter Property="RenderTransformOrigin"      Value="0.5,0.5"/>
              <Setter Property="RenderTransform">
                  <Setter.Value>
                      <ScaleTransform ScaleX="1" ScaleY="1"/>
                  </Setter.Value>
              </Setter>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd"
                                  CornerRadius="{StaticResource CornerBtn}"
                                  Padding="{TemplateBinding Padding}"
                                  RenderTransformOrigin="0.5,0.5">
                              <Border.Background>
                                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                      <GradientStop Color="#7C3AED" Offset="0"/>
                                      <GradientStop Color="#DB2777" Offset="1"/>
                                  </LinearGradientBrush>
                              </Border.Background>
                              <Border.Effect>
                                  <DropShadowEffect x:Name="BtnShadow"
                                                    Color="#7C3AED"
                                                    BlurRadius="0"
                                                    ShadowDepth="0"
                                                    Opacity="0"/>
                              </Border.Effect>
                              <Border.RenderTransform>
                                  <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsEnabled" Value="False">
                                  <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                              </Trigger>
                              <EventTrigger RoutedEvent="Button.MouseEnter">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.04" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1.04" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnShadow"
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="14" Duration="0:0:0.20"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.40" Duration="0:0:0.20"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.MouseLeave">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnShadow"
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="0" Duration="0:0:0.15"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0" Duration="0:0:0.15"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="0.96" Duration="0:0:0.08"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="0.96" Duration="0:0:0.08"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.25"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.25"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <Style x:Key="SecondaryButton" TargetType="Button">
              <Setter Property="Cursor"                Value="Hand"/>
              <Setter Property="Foreground"            Value="{DynamicResource TextSecondaryBrush}"/>
              <Setter Property="FontWeight"            Value="SemiBold"/>
              <Setter Property="Padding"               Value="18,9"/>
              <Setter Property="BorderThickness"       Value="1"/>
              <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd"
                                  Background="{DynamicResource BgElevatedBrush}"
                                  BorderBrush="{DynamicResource BorderDefaultBrush}"
                                  BorderThickness="1"
                                  CornerRadius="{StaticResource CornerBtn}"
                                  Padding="{TemplateBinding Padding}">
                              <Border.RenderTransform>
                                  <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsEnabled" Value="False">
                                  <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                              </Trigger>
                              <EventTrigger RoutedEvent="Button.MouseEnter">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.02" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1.02" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.MouseLeave">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="0.97" Duration="0:0:0.08"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="0.97" Duration="0:0:0.08"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.20"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.20"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Bd" Property="Background"   Value="{DynamicResource BgHoverBrush}"/>
                                  <Setter TargetName="Bd" Property="BorderBrush"  Value="{DynamicResource BorderStrongBrush}"/>
                                  <Setter Property="Foreground"                   Value="{DynamicResource TextPrimaryBrush}"/>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <Style x:Key="GhostButton" TargetType="Button">
              <Setter Property="Cursor"          Value="Hand"/>
              <Setter Property="Foreground"      Value="{DynamicResource TextMutedBrush}"/>
              <Setter Property="FontWeight"      Value="Medium"/>
              <Setter Property="Padding"         Value="14,8"/>
              <Setter Property="BorderThickness" Value="1"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd"
                                  Background="Transparent"
                                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                                  BorderThickness="1"
                                  CornerRadius="{StaticResource CornerSmall}"
                                  Padding="{TemplateBinding Padding}">
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource BgCardBrush}"/>
                                  <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                  <Setter Property="Foreground"                  Value="{DynamicResource TextSecondaryBrush}"/>
                              </Trigger>
                              <Trigger Property="IsPressed" Value="True">
                                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
                              </Trigger>
                              <Trigger Property="IsEnabled" Value="False">
                                  <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <Style x:Key="DangerButton" TargetType="Button">
              <Setter Property="Cursor"          Value="Hand"/>
              <Setter Property="Foreground"      Value="White"/>
              <Setter Property="FontWeight"      Value="SemiBold"/>
              <Setter Property="Padding"         Value="18,9"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd"
                                  Background="{DynamicResource DangerBrush}"
                                  CornerRadius="{StaticResource CornerBtn}"
                                  Padding="{TemplateBinding Padding}">
                              <Border.RenderTransform>
                                  <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsEnabled" Value="False">
                                  <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                              </Trigger>
                              <EventTrigger RoutedEvent="Button.MouseEnter">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.03" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1.03" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.MouseLeave">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="0.96" Duration="0:0:0.08"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="0.96" Duration="0:0:0.08"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.22"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.22"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <Style x:Key="SuccessButton" TargetType="Button">
              <Setter Property="Cursor"          Value="Hand"/>
              <Setter Property="Foreground"      Value="White"/>
              <Setter Property="FontWeight"      Value="SemiBold"/>
              <Setter Property="Padding"         Value="18,9"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="Button">
                          <Border x:Name="Bd"
                                  CornerRadius="{StaticResource CornerBtn}"
                                  Padding="{TemplateBinding Padding}">
                              <Border.Background>
                                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                      <GradientStop Color="#059669" Offset="0"/>
                                      <GradientStop Color="#10D9A0" Offset="1"/>
                                  </LinearGradientBrush>
                              </Border.Background>
                              <Border.RenderTransform>
                                  <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                              </Border.RenderTransform>
                              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Border>
                          <ControlTemplate.Triggers>
                              <Trigger Property="IsEnabled" Value="False">
                                  <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                              </Trigger>
                              <EventTrigger RoutedEvent="Button.MouseEnter">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.04" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1.04" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.MouseLeave">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.15"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="0.96" Duration="0:0:0.08"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="0.96" Duration="0:0:0.08"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1" Duration="0:0:0.22"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                          <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1" Duration="0:0:0.22"
                                                           EasingFunction="{StaticResource EaseBack}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

          <Style x:Key="NavItemStyle" TargetType="RadioButton">
              <Setter Property="Background"                 Value="Transparent"/>
              <Setter Property="Foreground"                 Value="#6E5E9A"/>
              <Setter Property="FontSize"                   Value="{DynamicResource GlobalFontSize}"/>
              <Setter Property="FontWeight"                 Value="Medium"/>
              <Setter Property="Padding"                    Value="11,10"/>
              <Setter Property="Margin"                     Value="0,1"/>
              <Setter Property="HorizontalContentAlignment" Value="Left"/>
              <Setter Property="Cursor"                     Value="Hand"/>
              <Setter Property="Template">
                  <Setter.Value>
                      <ControlTemplate TargetType="RadioButton">
                          <Grid>
                              <!-- Subtle hover glow layer -->
                              <Border x:Name="GlowLayer"
                                      CornerRadius="{StaticResource CornerSmall}"
                                      Opacity="0" Margin="0,1,4,1">
                                  <Border.Background>
                                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                          <GradientStop Color="#0D0926" Offset="0"/>
                                          <GradientStop Color="#120D28" Offset="1"/>
                                      </LinearGradientBrush>
                                  </Border.Background>
                              </Border>
                              <!-- Main item border -->
                              <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                      CornerRadius="{StaticResource CornerSmall}"
                                      Padding="{TemplateBinding Padding}"
                                      Margin="0,0,4,0">
                                  <Border.RenderTransform>
                                      <TranslateTransform x:Name="BdSlide" X="0"/>
                                  </Border.RenderTransform>
                                  <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="Center"
                                                    RecognizesAccessKey="False"/>
                              </Border>
                              <!-- Active indicator bar — gradient violet→rose -->
                              <Border x:Name="Indicator" Width="3" HorizontalAlignment="Left"
                                      CornerRadius="0,3,3,0" Visibility="Collapsed"
                                      Margin="0,6,0,6">
                                  <Border.Background>
                                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                          <GradientStop Color="#A855F7" Offset="0"/>
                                          <GradientStop Color="#7C3AED" Offset="0.5"/>
                                          <GradientStop Color="#DB2777" Offset="1"/>
                                      </LinearGradientBrush>
                                  </Border.Background>
                                  <Border.Effect>
                                      <DropShadowEffect Color="#7C3AED" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                  </Border.Effect>
                              </Border>
                          </Grid>
                          <ControlTemplate.Triggers>
                              <EventTrigger RoutedEvent="RadioButton.MouseEnter">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="GlowLayer"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="1" Duration="0:0:0.18"
                                                           EasingFunction="{StaticResource EaseOut}"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <EventTrigger RoutedEvent="RadioButton.MouseLeave">
                                  <BeginStoryboard>
                                      <Storyboard>
                                          <DoubleAnimation Storyboard.TargetName="GlowLayer"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0" Duration="0:0:0.18"/>
                                      </Storyboard>
                                  </BeginStoryboard>
                              </EventTrigger>
                              <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="Bd" Property="Background"  Value="Transparent"/>
                                  <Setter Property="Foreground"                  Value="#9880C8"/>
                              </Trigger>
                              <Trigger Property="IsChecked" Value="True">
                                  <Setter TargetName="Bd"        Property="Background"  Value="#14103A"/>
                                  <Setter TargetName="Bd"        Property="BorderThickness" Value="1"/>
                                  <Setter TargetName="Bd"        Property="BorderBrush" Value="#281858"/>
                                  <Setter TargetName="Indicator" Property="Visibility"  Value="Visible"/>
                                  <Setter TargetName="GlowLayer" Property="Opacity"     Value="0"/>
                                  <Setter Property="Foreground"  Value="#D4C8FF"/>
                                  <Setter Property="FontWeight"  Value="SemiBold"/>
                              </Trigger>
                          </ControlTemplate.Triggers>
                      </ControlTemplate>
                  </Setter.Value>
              </Setter>
          </Style>

      </ResourceDictionary>
  </Application.Resources>
</Application>

