## .gitignore pour projet C# WPF + Site Web (Coclico)

# Build outputs
[Bb]in/
[Oo]bj/
out/
build/
dist/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Rider / JetBrains
.idea/
*.DotSettings.user

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
nuget.config

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Publish
publish/
*.pubxml
*.pubxml.user

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Node / Web
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.production

# AI Model (large binary, not in repo)
resource/model/*.gguf
resource/model/*.bin

# User data
%AppData%/Coclico/

# Sensitive
*.pfx
*.p12
secrets.json
appsettings.Development.json
