---
import type { Lang } from '../../i18n/index';
import { useTranslations, languages, getLocalePath, getLangFromUrl } from '../../i18n/index';

interface Props { lang: Lang; currentPath?: string; }
const { lang, currentPath = '/' } = Astro.props;
const BASE = (import.meta.env.BASE_URL || '/');
const t = useTranslations(lang);

const navLinks = [
  { key: 'nav_modules',     hash: '#modules'  },
  { key: 'nav_ai',          hash: '#ai'       },
  { key: 'nav_performance', page: '/faq/', fragment: '#performance' },
  { key: 'nav_docs',        page: '/docs/'    },
  { key: 'nav_guide',       page: '/guide/'   },
  { key: 'nav_wiki',        page: '/wiki/'    },
  { key: 'nav_faq',         page: '/faq/'     },
  { key: 'nav_changelog',   page: '/changelog/' },
] as const;
---

<header class="nav" id="main-nav" role="banner">
  <div class="nav-inner container">

    <!-- Logo -->
    <a href={getLocalePath('/', lang)} class="nav-logo" aria-label="Coclico — Accueil">
      <div class="nav-logo-icon" aria-hidden="true">
        <img src={BASE + 'apple-touch-icon.png'} alt="Coclico" width="32" height="32" style="border-radius:6px;" />
      </div>
      <span class="nav-logo-text">Coclico</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="nav-links" aria-label="Navigation principale">
      {navLinks.map((link) => {
        const hash = 'hash' in link ? (link as any).hash : undefined;
        const page = 'page' in link ? (link as any).page : undefined;
        const fragment = 'fragment' in link ? (link as any).fragment : undefined;

        const href = hash
          ? getLocalePath('/', lang) + hash
          : fragment
            ? getLocalePath(page!, lang) + fragment
            : getLocalePath(page!, lang);

        return (
          <a
            href={href}
            class="nav-link"
            data-hash={hash ?? null}
          >
            {t(link.key as any)}
          </a>
        );
      })}
    </nav>

    <!-- Actions droite -->
    <div class="nav-actions">
      <!-- Sélecteur de langue -->
      <div class="lang-selector" id="lang-selector">
        <button class="lang-current" aria-expanded="false" aria-haspopup="listbox" aria-label="Changer de langue">
          <span class="lang-flag">{languages[lang].flag}</span>
          <span class="lang-code">{lang.toUpperCase()}</span>
          <svg class="lang-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="lang-dropdown" role="listbox" aria-label="Langues disponibles">
          {(Object.entries(languages) as [Lang, { label: string; flag: string }][]).map(([code, { label, flag }]) => (
            <a
              href={getLocalePath(currentPath, code)}
              class:list={['lang-option', { active: code === lang }]}
              role="option"
              aria-selected={code === lang}
              data-lang={code}
            >
              <span>{flag}</span>
              <span>{label}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Toggle Dark/Light -->
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label={t('toggle_dark')}
        title={t('toggle_dark')}
      >
        <!-- Icône soleil (mode clair) -->
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Icône lune (mode sombre) -->
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Bouton téléchargement (desktop) -->
      <a href={getLocalePath('#download', lang)} class="btn-primary nav-download hide-mobile">
        {t('nav_download')}
      </a>

      <!-- Hamburger mobile -->
      <button class="hamburger hide-desktop" id="hamburger" aria-label={t('nav_open_menu')} aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Menu de navigation">
    <nav>
      {navLinks.map((link) => {
        const hash = 'hash' in link ? (link as any).hash : undefined;
        const page = 'page' in link ? (link as any).page : undefined;
        const fragment = 'fragment' in link ? (link as any).fragment : undefined;

        const href = hash
          ? getLocalePath('/', lang) + hash
          : fragment
            ? getLocalePath(page!, lang) + fragment
            : getLocalePath(page!, lang);

        return (
          <a
            href={href}
            class="mobile-link"
            data-hash={hash ?? null}
          >
            {t(link.key as any)}
          </a>
        );
      })}
    </nav>
    <div class="mobile-menu-footer">
      <a href={getLocalePath('#download', lang)} class="btn-primary" style="width:100%;justify-content:center">
        {t('nav_download')}
      </a>
      <div class="mobile-langs">
        {(Object.entries(languages) as [Lang, { label: string; flag: string }][]).map(([code, { label, flag }]) => (
          <a
            href={getLocalePath(currentPath, code)}
            class:list={['mobile-lang', { active: code === lang }]}
            data-lang={code}
          >
            <span>{flag}</span> {code.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
/* ── Nav container ───────────────────────────────────────────────── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: var(--z-nav);
  padding: 0;
  transition: background var(--duration-base) var(--ease-out),
              backdrop-filter var(--duration-base) var(--ease-out),
              box-shadow var(--duration-base) var(--ease-out);
}

.nav.scrolled {
  background: rgba(3, 3, 10, 0.85);
  backdrop-filter: blur(20px) saturate(1.5);
  -webkit-backdrop-filter: blur(20px) saturate(1.5);
  box-shadow: 0 1px 0 var(--border), 0 4px 24px rgba(0,0,0,0.4);
}

.light .nav.scrolled {
  background: rgba(248, 248, 252, 0.85);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 1rem;
  height: 68px;
}

/* ── Logo ───────────────────────────────────────────────────────── */
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  flex-shrink: 0;
}

.nav-logo-icon {
  display: flex;
  align-items: center;
  transition: transform var(--duration-base) var(--ease-spring);
}

.nav-logo:hover .nav-logo-icon {
  transform: rotate(-8deg) scale(1.05);
}

.nav-logo-text {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.03em;
}

/* ── Nav links (desktop) ────────────────────────────────────────── */
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex: 1;
  justify-content: center;
}

.nav-link {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-2);
  padding: 0.45rem 0.75rem;
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out),
              background var(--duration-fast) var(--ease-out);
  white-space: nowrap;
}

.nav-link:hover {
  color: var(--text);
  background: var(--surface-hover);
}

.nav-link.active {
  color: var(--accent-hover);
  background: var(--accent-dim);
}

/* ── Actions droite ─────────────────────────────────────────────── */
.nav-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.nav-download {
  font-size: 0.85rem;
  padding: 0.5rem 1.1rem;
}

/* ── Sélecteur de langue ────────────────────────────────────────── */
.lang-selector {
  position: relative;
}

.lang-current {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 0.45rem 0.75rem;
  cursor: pointer;
  color: var(--text-2);
  font-size: 0.8rem;
  font-weight: 600;
  font-family: var(--font-mono);
  transition: background var(--duration-fast) var(--ease-out),
              border-color var(--duration-fast) var(--ease-out);
}

.lang-current:hover {
  background: var(--surface-hover);
  border-color: var(--border-hover);
  color: var(--text);
}

.lang-flag { font-size: 1rem; line-height: 1; }
.lang-code { letter-spacing: 0.05em; }

.lang-chevron {
  color: var(--text-3);
  transition: transform var(--duration-base) var(--ease-out);
}

.lang-selector.open .lang-chevron {
  transform: rotate(180deg);
}

.lang-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: var(--bg-2);
  border: 1px solid var(--border-hover);
  border-radius: var(--radius-md);
  padding: 0.4rem;
  min-width: 150px;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-6px) scale(0.97);
  transform-origin: top right;
  transition: opacity var(--duration-base) var(--ease-out),
              transform var(--duration-base) var(--ease-out);
  z-index: 10;
}

.lang-selector.open .lang-dropdown {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0) scale(1);
}

.lang-option {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.5rem 0.75rem;
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  color: var(--text-2);
  text-decoration: none;
  transition: background var(--duration-fast) var(--ease-out),
              color var(--duration-fast) var(--ease-out);
}

.lang-option:hover { background: var(--surface-hover); color: var(--text); }
.lang-option.active { color: var(--accent-hover); background: var(--accent-dim); }

/* ── Theme toggle ───────────────────────────────────────────────── */
.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px; height: 36px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  cursor: pointer;
  color: var(--text-2);
  transition: background var(--duration-fast) var(--ease-out),
              border-color var(--duration-fast) var(--ease-out),
              color var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-spring);
}

.theme-toggle:hover {
  background: var(--surface-hover);
  border-color: var(--border-hover);
  color: var(--text);
  transform: rotate(15deg);
}

.dark  .icon-sun  { display: none; }
.light .icon-moon { display: none; }
.dark  .icon-moon { display: block; }
.light .icon-sun  { display: block; }

/* ── Hamburger ──────────────────────────────────────────────────── */
.hamburger {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 36px; height: 36px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  cursor: pointer;
  padding: 8px;
}

.hamburger span {
  display: block;
  width: 18px; height: 1.5px;
  background: var(--text-2);
  border-radius: 2px;
  transition: transform var(--duration-base) var(--ease-out),
              opacity var(--duration-base) var(--ease-out);
  transform-origin: center;
}

.hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* ── Menu mobile ────────────────────────────────────────────────── */
.mobile-menu {
  display: none;
  flex-direction: column;
  gap: 0.25rem;
  background: var(--bg-2);
  border-top: 1px solid var(--border);
  padding: 1rem 1.5rem 1.5rem;
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--duration-slow) var(--ease-out),
              opacity var(--duration-slow) var(--ease-out);
  opacity: 0;
}

.mobile-menu.open {
  display: flex;
  max-height: 600px;
  opacity: 1;
}

.mobile-link {
  display: block;
  font-size: 1rem;
  font-weight: 500;
  color: var(--text-2);
  padding: 0.7rem 0.5rem;
  border-bottom: 1px solid var(--border);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}

.mobile-link:hover { color: var(--text); }

.mobile-menu-footer {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: 1rem;
  padding-top: 1rem;
}

.mobile-langs {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.mobile-lang {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8rem;
  font-family: var(--font-mono);
  font-weight: 600;
  padding: 0.35rem 0.7rem;
  border-radius: var(--radius-full);
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-2);
  text-decoration: none;
  transition: all var(--duration-fast) var(--ease-out);
}

.mobile-lang.active {
  background: var(--accent-dim);
  border-color: var(--border-accent);
  color: var(--accent-hover);
}

/* ── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 1023px) {
  .nav-links { display: none; }
}

@media (max-width: 767px) {
  .hide-mobile { display: none !important; }
}

@media (min-width: 768px) {
  .hide-desktop { display: none !important; }
}
</style>

<script>
// ── Nav scroll effect ─────────────────────────────────────────────
const nav = document.getElementById('main-nav')!;
const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 20);
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ── Hamburger / menu mobile ───────────────────────────────────────
const hamburger = document.getElementById('hamburger')!;
const mobileMenu = document.getElementById('mobile-menu')!;

hamburger.addEventListener('click', () => {
  const isOpen = hamburger.classList.toggle('open');
  mobileMenu.classList.toggle('open', isOpen);
  hamburger.setAttribute('aria-expanded', String(isOpen));
  mobileMenu.setAttribute('aria-hidden', String(!isOpen));
});

// Fermer le menu mobile sur clic d'un lien
mobileMenu.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    hamburger.classList.remove('open');
    mobileMenu.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    mobileMenu.setAttribute('aria-hidden', 'true');
  });
});

// ── Sélecteur de langue ───────────────────────────────────────────
const langSelector = document.getElementById('lang-selector')!;
const langBtn = langSelector.querySelector('.lang-current')!;

langBtn.addEventListener('click', (e) => {
  e.stopPropagation();
  const isOpen = langSelector.classList.toggle('open');
  langBtn.setAttribute('aria-expanded', String(isOpen));
});

document.addEventListener('click', (e) => {
  if (!langSelector.contains(e.target as Node)) {
    langSelector.classList.remove('open');
    langBtn.setAttribute('aria-expanded', 'false');
  }
});

// Fermer avec Escape
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    langSelector.classList.remove('open');
    langBtn.setAttribute('aria-expanded', 'false');
  }
});

// Sauvegarder le choix de langue
langSelector.querySelectorAll('[data-lang]').forEach(link => {
  link.addEventListener('click', () => {
    localStorage.setItem('coclico-lang', (link as HTMLElement).dataset.lang!);
  });
});

// ── Toggle Dark / Light ───────────────────────────────────────────
const themeToggle = document.getElementById('theme-toggle')!;

themeToggle.addEventListener('click', () => {
  const isDark = document.documentElement.classList.contains('dark');
  document.documentElement.classList.toggle('dark', !isDark);
  document.documentElement.classList.toggle('light', isDark);
  localStorage.setItem('coclico-theme', isDark ? 'light' : 'dark');
});

// ── Active link highlight ─────────────────────────────────────────
const currentPath = window.location.pathname;
document.querySelectorAll('.nav-link, .mobile-link').forEach(link => {
  const href = link.getAttribute('href') ?? '';
  if (!href.startsWith('#') && currentPath.startsWith(href) && href !== '/') {
    link.classList.add('active');
  }
});

// ── Smooth scroll pour les ancres (seulement si la section existe sur la page courante) ──
document.querySelectorAll('[data-hash]').forEach(link => {
  link.addEventListener('click', (e) => {
    const hash = (link as HTMLElement).dataset.hash;
    if (!hash) return;
    const target = document.querySelector(hash);
    if (target) {
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth' });
      history.replaceState(null, '', hash);
    }
    // Si la section n'existe pas sur la page courante, le lien href redirige vers la homepage + hash
  });
});
</script>
