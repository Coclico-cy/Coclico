---
import type { Lang } from '../../i18n/index';
import { useTranslations } from '../../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  { key: 'ai_feat1', color: '#22c55e' },
  { key: 'ai_feat2', color: '#6366f1' },
  { key: 'ai_feat3', color: '#f97316' },
  { key: 'ai_feat4', color: '#06b6d4' },
  { key: 'ai_feat5', color: '#a855f7' },
] as const;
---

<section class="ai-section" id="ai" aria-labelledby="ai-heading">
  <div class="container">
    <div class="ai-layout">

      <!-- Démo chat (gauche) -->
      <div class="ai-demo gsap-fade-up" aria-label="Démo assistant IA local">
        <div class="chat-window">
          <div class="chat-header">
            <div class="chat-status">
              <span class="chat-status-dot" aria-hidden="true"></span>
              <span class="chat-status-label">Coclico AI · Local · LLamaSharp 0.26</span>
            </div>
            <div class="chat-badges">
              <span class="badge" style="background:rgba(34,197,94,0.1);color:#22c55e;border-color:rgba(34,197,94,0.3)">GGUF</span>
              <span class="badge" style="background:rgba(6,182,212,0.1);color:#06b6d4;border-color:rgba(6,182,212,0.3)">Vulkan/CPU</span>
            </div>
          </div>

          <div class="chat-messages" role="log" aria-live="polite" aria-label="Messages de l'assistant IA">
            <!-- Message utilisateur 1 -->
            <div class="msg user" role="article" aria-label="Vous">
              <div class="msg-bubble">Comment libérer de la RAM rapidement ?</div>
            </div>
            <!-- Réponse IA 1 -->
            <div class="msg ai" role="article" aria-label="Coclico AI">
              <div class="msg-avatar" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 28 28" fill="none">
                  <rect width="28" height="28" rx="8" fill="url(#chat-grad)"/>
                  <path d="M8 14C8 10.686 10.686 8 14 8C15.5 8 16.87 8.56 17.9 9.48L15.76 11.62C15.25 11.23 14.65 11 14 11C12.34 11 11 12.34 11 14C11 15.66 12.34 17 14 17C14.65 17 15.25 16.77 15.76 16.38L17.9 18.52C16.87 19.44 15.5 20 14 20C10.686 20 8 17.314 8 14Z" fill="white"/>
                  <defs>
                    <linearGradient id="chat-grad" x1="0" y1="0" x2="28" y2="28">
                      <stop stop-color="#6366f1"/><stop offset="1" stop-color="#a855f7"/>
                    </linearGradient>
                  </defs>
                </svg>
              </div>
              <div class="msg-bubble">
                Le module <strong>RAM Cleaner</strong> surveille votre mémoire physique, virtuelle et le Pagefile en temps réel. Profil <code>Rapide</code> pour un gain immédiat, <code>Profond</code> pour vider la Standby List. Voulez-vous que je l'ouvre ?
                <div class="msg-action">
                  <button class="msg-btn" type="button">Ouvrir RAM Cleaner →</button>
                </div>
              </div>
            </div>
            <!-- Message utilisateur 2 -->
            <div class="msg user" role="article" aria-label="Vous">
              <div class="msg-bubble">Crée un Flow Chain qui nettoie la RAM toutes les 30 min</div>
            </div>
            <!-- Réponse IA 2 -->
            <div class="msg ai typing" role="article" aria-label="Coclico AI">
              <div class="msg-avatar" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 28 28" fill="none">
                  <rect width="28" height="28" rx="8" fill="url(#chat-grad2)"/>
                  <path d="M8 14C8 10.686 10.686 8 14 8C15.5 8 16.87 8.56 17.9 9.48L15.76 11.62C15.25 11.23 14.65 11 14 11C12.34 11 11 12.34 11 14C11 15.66 12.34 17 14 17C14.65 17 15.25 16.77 15.76 16.38L17.9 18.52C16.87 19.44 15.5 20 14 20C10.686 20 8 17.314 8 14Z" fill="white"/>
                  <defs>
                    <linearGradient id="chat-grad2" x1="0" y1="0" x2="28" y2="28">
                      <stop stop-color="#6366f1"/><stop offset="1" stop-color="#a855f7"/>
                    </linearGradient>
                  </defs>
                </svg>
              </div>
              <div class="msg-bubble">
                Chaîne créée : <code>START → RamClean → Delay(1800s) → BOUCLE → END</code>. Déclencheur auto activé toutes les <strong>30 min</strong>.
                <div class="msg-action">
                  <button class="msg-btn" type="button">Voir la chaîne →</button>
                </div>
              </div>
            </div>
          </div>

          <div class="chat-input-area">
            <div class="chat-input-fake" aria-label="Zone de saisie (démo statique)">
              <span class="chat-input-placeholder">Posez une question à Coclico AI…</span>
              <span class="chat-cursor" aria-hidden="true"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Texte (droite) -->
      <div class="ai-text gsap-fade-up">
        <div class="section-tag">
          <span class="badge">Coclico AI</span>
        </div>
        <h2 id="ai-heading">{t('ai_title')}</h2>
        <p class="ai-desc">{t('ai_desc')}</p>

        <div class="ai-features" role="list">
          {features.map(({ key, color }) => (
            <div class="ai-feat" role="listitem" style={`--feat-color: ${color}`}>
              <div class="ai-feat-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <div>
                <strong>{t(`${key}_title` as any)}</strong>
                <p>{t(`${key}_desc` as any)}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Spec technique -->
        <div class="ai-spec">
          <div class="ai-spec-item">
            <span class="ai-spec-k">Model</span>
            <span class="ai-spec-v">GGUF local</span>
          </div>
          <div class="ai-spec-item">
            <span class="ai-spec-k">Runtime</span>
            <span class="ai-spec-v">LLamaSharp 0.26</span>
          </div>
          <div class="ai-spec-item">
            <span class="ai-spec-k">Backend</span>
            <span class="ai-spec-v">CPU / Vulkan</span>
          </div>
          <div class="ai-spec-item">
            <span class="ai-spec-k">Réseau</span>
            <span class="ai-spec-v">Aucun</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.ai-section { padding: 7rem 0; }

.ai-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4rem;
  align-items: center;
}

@media (min-width: 1024px) {
  .ai-layout { grid-template-columns: 1.2fr 1fr; gap: 5rem; }
}

/* Chat window */
.chat-window {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg), 0 0 60px rgba(99,102,241,0.08);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1.25rem;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  flex-wrap: wrap;
  gap: 0.5rem;
}

.chat-status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.chat-status-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 6px rgba(34,197,94,0.6);
  animation: glow-pulse 2s ease-in-out infinite;
}

@keyframes glow-pulse {
  0%,100% { box-shadow: 0 0 6px rgba(34,197,94,0.6); }
  50%      { box-shadow: 0 0 12px rgba(34,197,94,0.9); }
}

.chat-status-label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-3);
}

.chat-badges { display: flex; gap: 0.3rem; }
.chat-badges .badge { font-size: 0.6rem; padding: 0.2em 0.5em; }

/* Messages */
.chat-messages {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  min-height: 220px;
}

.msg {
  display: flex;
  gap: 0.6rem;
  align-items: flex-end;
}

.msg.user { justify-content: flex-end; }

.msg-avatar {
  width: 24px; height: 24px;
  flex-shrink: 0;
  border-radius: 6px;
  overflow: hidden;
}

.msg-bubble {
  max-width: 80%;
  padding: 0.65rem 0.9rem;
  border-radius: 12px;
  font-size: 0.82rem;
  line-height: 1.55;
}

.msg.user .msg-bubble {
  background: var(--accent);
  color: white;
  border-radius: 12px 12px 2px 12px;
}

.msg.ai .msg-bubble {
  background: var(--surface-hover);
  border: 1px solid var(--border);
  color: var(--text-2);
  border-radius: 2px 12px 12px 12px;
}

.msg-bubble strong { color: var(--text); }
.msg-bubble code {
  background: var(--accent-dim);
  color: var(--accent-hover);
  padding: 0.1em 0.4em;
  border-radius: 4px;
  border: none;
  font-size: 0.78em;
}

.msg-action { margin-top: 0.6rem; }

.msg-btn {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--accent-hover);
  background: var(--accent-dim);
  border: 1px solid var(--border-accent);
  padding: 0.3em 0.75em;
  border-radius: var(--radius-full);
  cursor: pointer;
  transition: background var(--duration-fast), transform var(--duration-fast) var(--ease-spring);
}
.msg-btn:hover {
  background: color-mix(in srgb, var(--accent) 20%, transparent);
  transform: translateY(-1px);
}

/* Input */
.chat-input-area {
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--border);
  background: var(--surface);
}

.chat-input-fake {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.75rem;
  background: var(--bg-3);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
}

.chat-input-placeholder {
  font-size: 0.8rem;
  color: var(--text-4);
  flex: 1;
}

.chat-cursor {
  width: 2px; height: 14px;
  background: var(--accent);
  animation: blink 1.1s step-end infinite;
}

@keyframes blink {
  0%,100% { opacity: 1; }
  50%      { opacity: 0; }
}

/* Texte AI */
.ai-text {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.ai-desc {
  font-size: 1rem;
  color: var(--text-2);
  line-height: 1.7;
}

.ai-features {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
  margin-top: 0.5rem;
}

.ai-feat {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
}

.ai-feat-icon {
  width: 22px; height: 22px;
  background: color-mix(in srgb, var(--feat-color) 15%, transparent);
  border: 1px solid color-mix(in srgb, var(--feat-color) 30%, transparent);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--feat-color);
  flex-shrink: 0;
  margin-top: 2px;
}

.ai-feat strong {
  display: block;
  font-size: 0.875rem;
  color: var(--text);
  margin-bottom: 0.15rem;
}

.ai-feat p {
  font-size: 0.78rem;
  color: var(--text-3);
  line-height: 1.5;
}

/* Spec */
.ai-spec {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
  padding: 1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  margin-top: 0.5rem;
}

.ai-spec-item {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.ai-spec-k {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--text-4);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.ai-spec-v {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text);
  font-family: var(--font-mono);
}
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

gsap.fromTo('.ai-demo', { opacity: 0, x: -30 }, {
  opacity: 1, x: 0, duration: 0.8, ease: 'power3.out',
  scrollTrigger: { trigger: '.ai-section', start: 'top 75%', once: true },
});

gsap.fromTo('.ai-text', { opacity: 0, x: 30 }, {
  opacity: 1, x: 0, duration: 0.8, ease: 'power3.out', delay: 0.15,
  scrollTrigger: { trigger: '.ai-section', start: 'top 75%', once: true },
});

gsap.fromTo('.ai-feat', { opacity: 0, x: 15 }, {
  opacity: 1, x: 0, duration: 0.5, stagger: 0.08, ease: 'power2.out',
  scrollTrigger: { trigger: '.ai-features', start: 'top 85%', once: true },
});
</script>
